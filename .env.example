# RainBot Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# Scheduler Configuration
# ============================================
# How often the booking job runs (interval)
HOUR=0
MINUTE=0
SECOND=10
JITTER=0

# ============================================
# Google Sheets Configuration
# ============================================
# The ID of your Google Spreadsheet (from the URL)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Path to your Google service account credentials JSON file
GOOGLE_CREDENTIALS_FILE=./credentials.json

# ============================================
# 2Captcha Configuration
# ============================================
# Your 2Captcha API key for solving CAPTCHAs
CAPTCHA_API_KEY=your_2captcha_api_key_here

# ============================================
# Email Notification Configuration
# ============================================
# SMTP server settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
FROM_EMAIL=your_email@gmail.com

# ============================================
# Optional Settings
# ============================================
# Set to true to enable debug mode (disables headless browser)
DEBUG=false
